flowchart TD
  trigger_issue(("NEW ISSUE"))
  subgraph issue pipeline
    issue-classifier --> prd-writer
    prd-writer --> product-standards-checker
    product-standards-checker --> impact-assessor
    impact-assessor --> dependency-resolver
    dependency-resolver --> ticket-sizer
    impact-assessor --> ticket-sizer
    ticket-sizer --> architect
    architect --> adr-proposer
    architect --> test-spec-writer
    prd-writer --> test-spec-writer
    test-spec-writer --> test-coverage-auditor
    architect --> task-decomposer
    test-spec-writer --> task-decomposer
    task-decomposer --> dependency-planner
    dependency-planner --> coder
    release-noter --> retrospective-writer
    retrospective-writer --> standards-evolver
    trigger_issue --> issue-classifier
    prd-writer -->|prd:approved| prd-writer_HUMAN
    prd-writer_HUMAN([Human Gate: prd:approved])
    ticket-sizer -->|size:approved| ticket-sizer_HUMAN
    ticket-sizer_HUMAN([Human Gate: size:approved])
    architect -->|design:approved| architect_HUMAN
    architect_HUMAN([Human Gate: design:approved])
    test-coverage-auditor -->|test-spec:approved| test-coverage-auditor_HUMAN
    test-coverage-auditor_HUMAN([Human Gate: test-spec:approved])
    dependency-planner -->|plan:approved| dependency-planner_HUMAN
    dependency-planner_HUMAN([Human Gate: plan:approved])
    standards-evolver -->|standards-proposal:approved| standards-evolver_HUMAN
    standards-evolver_HUMAN([Human Gate: standards-proposal:approved])
  end
  trigger_pr(("NEW PR"))
  subgraph pr pipeline
    coder --> standards-compliance-reviewer
    coder --> migration-validator
    coder --> pr-reviewer
    standards-compliance-reviewer --> pr-reviewer
    pr-reviewer --> test-writer
    test-writer --> test-runner
    test-runner --> coverage-enforcer
    pr-reviewer -->|pr:approved| pr-reviewer_HUMAN
    pr-reviewer_HUMAN([Human Gate: pr:approved])
    coverage-enforcer -->|coverage:approved| coverage-enforcer_HUMAN
    coverage-enforcer_HUMAN([Human Gate: coverage:approved])
  end