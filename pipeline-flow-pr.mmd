%% Pipeline for pr
    coder --> standards-compliance-reviewer
    coder --> migration-validator
    coder --> pr-reviewer
    standards-compliance-reviewer --> pr-reviewer
    pr-reviewer --> test-writer
    test-writer --> test-runner
    test-runner --> coverage-enforcer
    pr-reviewer -->|pr:approved| pr-reviewer_HUMAN
    pr-reviewer_HUMAN([Human Gate: pr:approved])
    coverage-enforcer -->|coverage:approved| coverage-enforcer_HUMAN
    coverage-enforcer_HUMAN([Human Gate: coverage:approved])